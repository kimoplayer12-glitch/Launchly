# Copy this file to .env and fill in values.

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/zenith

VITE_PUBLIC_BUILDER_KEY=

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_DATABASE_URL=
# Backend runtime key for Firebase Identity Toolkit (if omitted, falls back to VITE_FIREBASE_API_KEY)
FIREBASE_API_KEY=
# Required for backend Google token verification (JSON stringified service account)
FIREBASE_SERVICE_ACCOUNT=

PING_MESSAGE="ping pong"

JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d

# Base URL for OAuth redirects
APP_BASE_URL=http://localhost:8080

# OpenAI (Workflow AI nodes)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Redis / BullMQ
REDIS_URL=redis://localhost:6379
# Runs hourly and dispatches only when each user's local/server hour is 08:00
DAILY_MOTIVATION_CRON=0 * * * *

# Nango (OAuth management)
NANGO_BASE_URL=
NANGO_SECRET_KEY=
NANGO_CONNECT_URL=
NANGO_ENCRYPTION_KEY=
NANGO_JWT_SECRET=
# Optional: override integration keys if they differ from provider names
NANGO_INTEGRATION_STRIPE=
NANGO_INTEGRATION_PAYPAL=
NANGO_INTEGRATION_SHOPIFY=
NANGO_INTEGRATION_INSTAGRAM=
NANGO_INTEGRATION_TIKTOK=

# Optional: Email sending via Resend
RESEND_API_KEY=
RESEND_FROM_EMAIL="Launchly <onboarding@resend.dev>"
ADMIN_TRIGGER_TOKEN=
ADMIN_EMAILS=

# Optional: Stripe subscriptions (your SaaS)
STRIPE_SECRET_KEY=
STRIPE_CLIENT_ID=

# Optional: Stripe Connect (your users connect their Stripe)
STRIPE_CONNECT_CLIENT_ID=
STRIPE_CONNECT_REDIRECT_URI=

# Optional: PayPal
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=

# Optional: Meta (Instagram/Facebook)
META_APP_ID=
META_APP_SECRET=

# Optional: TikTok
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# Optional: Shopify app OAuth start
SHOPIFY_API_KEY=
SHOPIFY_SCOPES=read_products,write_products,read_orders,read_customers
SHOPIFY_REDIRECT_URI=

# Social Media OAuth - Instagram/Meta
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=

# Social Media OAuth - Twitter
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# Social Media OAuth - TikTok
TIKTOK_CLIENT_ID=
TIKTOK_CLIENT_SECRET=


# OAuth Redirect URI (for all platforms)
OAUTH_REDIRECT_URI=http://localhost:8081/api/social/oauth/callback

# Token Encryption (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
ENCRYPTION_KEY=

# Workflow Automation (Firebase-backed)
# 32-byte key (base64 or hex) for AES-256-GCM encryption of credentials
WORKFLOW_CREDENTIALS_KEY=
